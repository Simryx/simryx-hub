<Window x:Class="Simryx.Setup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Установка Simryx Hub"
        Width="720" Height="540" MinWidth="640" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Background="{DynamicResource Brush.Bg}"
        Foreground="{DynamicResource Brush.Text}">

    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="◆ Simryx Hub" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource Brush.Accent}"/>
            <TextBlock x:Name="StepTitle" FontSize="14" Margin="0,4,0,0"
                       Foreground="{DynamicResource Brush.Subtle}"/>
        </StackPanel>

        <!-- Карточка с содержимым шага -->
        <Border Grid.Row="1" Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                CornerRadius="12" Padding="22">
            <Grid>
                <!-- Приветствие -->
                <StackPanel x:Name="PanelWelcome" Visibility="Collapsed">
                    <TextBlock Text="Установка Simryx Hub" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Brush.Subtle}"
                               Text="Мастер установит на компьютер последнюю стабильную версию Simryx Hub — единого приложения для устройств Simryx."/>
                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Text="• Автоматическая загрузка актуальной версии" Margin="0,3"/>
                        <TextBlock Text="• Ярлыки в меню «Пуск» и на рабочем столе" Margin="0,3"/>
                        <TextBlock Text="• Регистрация в системе и удобное удаление" Margin="0,3"/>
                    </StackPanel>
                </StackPanel>

                <!-- Лицензия -->
                <Grid x:Name="PanelLicense" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Лицензионное соглашение" FontSize="18"
                               FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Border Grid.Row="1" Background="{DynamicResource Brush.Control}"
                            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8">
                        <TextBox x:Name="LicenseBox" IsReadOnly="True" BorderThickness="0"
                                 Background="Transparent" Foreground="{DynamicResource Brush.Text}"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 Padding="12" FontSize="12.5"/>
                    </Border>
                    <CheckBox x:Name="LicenseAccept" Grid.Row="2" Margin="0,12,0,0"
                              Foreground="{DynamicResource Brush.Text}"
                              Content="Я принимаю условия лицензионного соглашения"
                              Checked="LicenseAccept_Changed" Unchecked="LicenseAccept_Changed"/>
                </Grid>

                <!-- Путь установки -->
                <StackPanel x:Name="PanelLocation" Visibility="Collapsed">
                    <TextBlock Text="Папка установки" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Brush.Subtle}"
                               Text="Simryx Hub будет установлен в указанную папку. Права администратора не требуются."/>
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource Brush.Control}"
                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8">
                            <TextBox x:Name="PathBox" BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource Brush.Text}" Padding="12,9"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                        <Button Grid.Column="1" Content="Обзор…" Margin="10,0,0,0"
                                Style="{StaticResource GhostButton}" Click="Browse_Click"/>
                    </Grid>
                </StackPanel>

                <!-- Опции -->
                <StackPanel x:Name="PanelOptions" Visibility="Collapsed">
                    <TextBlock Text="Параметры" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <CheckBox x:Name="OptDesktop" IsChecked="True" Margin="0,6"
                              Foreground="{DynamicResource Brush.Text}"
                              Content="Создать ярлык на рабочем столе"/>
                    <CheckBox x:Name="OptStartup" Margin="0,6"
                              Foreground="{DynamicResource Brush.Text}"
                              Content="Запускать Simryx Hub вместе с Windows"/>
                    <CheckBox IsChecked="True" IsEnabled="False" Margin="0,6"
                              Foreground="{DynamicResource Brush.Subtle}"
                              Content="Добавить ярлык в меню «Пуск» (обязательно)"/>
                    <TextBlock TextWrapping="Wrap" Margin="0,14,0,0" FontSize="12"
                               Foreground="{DynamicResource Brush.Subtle}"
                               Text="«Запускать вместе с Windows» можно изменить позже в настройках самого приложения."/>
                </StackPanel>

                <!-- Прогресс -->
                <StackPanel x:Name="PanelProgress" Visibility="Collapsed" VerticalAlignment="Center">
                    <TextBlock x:Name="ProgressTitle" Text="Установка…" FontSize="18"
                               FontWeight="SemiBold" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="Bar" Height="8" IsIndeterminate="True"
                                 Foreground="{DynamicResource Brush.Accent}"
                                 Background="{DynamicResource Brush.Control}" BorderThickness="0"/>
                    <TextBlock x:Name="ProgressStatus" Margin="0,12,0,0" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Brush.Subtle}"/>
                </StackPanel>

                <!-- Завершение -->
                <StackPanel x:Name="PanelFinish" Visibility="Collapsed" VerticalAlignment="Center">
                    <TextBlock x:Name="FinishTitle" Text="Установка завершена" FontSize="20"
                               FontWeight="SemiBold" Margin="0,0,0,10" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Brush.Accent}"/>
                    <TextBlock x:Name="FinishText" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource Brush.Subtle}"/>
                    <CheckBox x:Name="LaunchNow" IsChecked="True" Margin="0,18,0,0"
                              HorizontalAlignment="Center" Foreground="{DynamicResource Brush.Text}"
                              Content="Запустить Simryx Hub сейчас"/>
                </StackPanel>

                <!-- Подтверждение удаления -->
                <StackPanel x:Name="PanelUninstall" Visibility="Collapsed" VerticalAlignment="Center">
                    <TextBlock Text="Удаление Simryx Hub" FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="UninstallText" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource Brush.Subtle}"
                               Text="Приложение и его ярлыки будут удалены с компьютера. Продолжить?"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Подвал -->
        <DockPanel Grid.Row="2" Margin="0,18,0,0" LastChildFill="False">
            <Button x:Name="BtnCancel" DockPanel.Dock="Left" Content="Отмена"
                    Style="{StaticResource GhostButton}" Click="Cancel_Click"/>
            <Button x:Name="BtnNext" DockPanel.Dock="Right" Content="Далее"
                    Style="{StaticResource AccentButton}" Click="Next_Click"/>
            <Button x:Name="BtnBack" DockPanel.Dock="Right" Content="Назад" Margin="0,0,10,0"
                    Style="{StaticResource GhostButton}" Click="Back_Click"/>
        </DockPanel>
    </Grid>
</Window>