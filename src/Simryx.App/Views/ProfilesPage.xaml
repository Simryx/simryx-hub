<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Simryx.App.Views.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Simryx.App.Models"
    mc:Ignorable="d">

    <Grid Margin="32,28,32,32" RowDefinitions="Auto,*">

        <!-- Заголовок + кнопка добавления -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,18">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock x:Uid="ProfilesTitle" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Uid="ProfilesSubtitle"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
            <Button x:Name="AddButton" Grid.Column="1" VerticalAlignment="Top" Click="Add_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE710;" />
                    <TextBlock x:Uid="ProfileAddButton" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Группы по играм -->
        <ScrollViewer x:Name="GroupsScroll" Grid.Row="1"
                      Padding="4,4,4,8"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <ItemsControl x:Name="GroupsList" ItemsSource="{x:Bind Groups}" HorizontalAlignment="Stretch">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:GameGroup">

                        <!-- Карточка группы -->
                        <Border Margin="0,0,0,12"
                                MaxWidth="860"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource SimryxCardBrush}"
                                BorderBrush="{ThemeResource SimryxCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>

                                <!-- Шапка (не кликабельна; переключает только кнопка-стрелка) -->
                                <Grid Background="Transparent"
                                      ColumnDefinitions="Auto,*,Auto,Auto"
                                      Padding="14,8,8,8">
                                    <FontIcon Grid.Column="0"
                                              Glyph="&#xE7FC;"
                                              FontSize="18"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource SimryxAccentBrush}" />
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               FontSize="15"
                                               Text="{x:Bind GameName}" />
                                    <Border Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Margin="0,0,6,0"
                                            MinWidth="22"
                                            Height="22"
                                            CornerRadius="11"
                                            Padding="7,0,7,0"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                        <TextBlock VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Text="{x:Bind CountText}" />
                                    </Border>

                                    <!-- Кнопка-стрелка: подсвечивается только она -->
                                    <Button Grid.Column="3"
                                            Click="ToggleGroup_Click"
                                            Width="32" Height="32"
                                            Padding="0"
                                            CornerRadius="8"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            VerticalAlignment="Center">
                                        <FontIcon Tag="chevron"
                                                  Glyph="&#xE70E;"
                                                  FontSize="14"
                                                  RenderTransformOrigin="0.5,0.5"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Button>
                                </Grid>

                                <!-- Содержимое группы (анимируемая высота) -->
                                <ListView Tag="profiles"
                                          Margin="14,2,14,14"
                                          SelectionMode="None"
                                          IsItemClickEnabled="False"
                                          ScrollViewer.VerticalScrollMode="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                          ScrollViewer.HorizontalScrollMode="Disabled"
                                          ItemsSource="{x:Bind Profiles}">
                                    <!-- Отключаем встроенные переходы, чтобы не конфликтовали с FLIP-анимацией перестановки -->
                                    <ListView.ItemContainerTransitions>
                                        <TransitionCollection />
                                    </ListView.ItemContainerTransitions>
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="MinHeight" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:RacingProfile">

                                            <Border Margin="0,4,0,4"
                                                    Background="{ThemeResource SimryxCardBrush}"
                                                    BorderBrush="{ThemeResource SimryxCardBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="14,12,14,12">
                                                <Grid ColumnDefinitions="*,Auto">

                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="5">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{x:Bind Name}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="14"
                                                                       VerticalAlignment="Center" />
                                                            <Border Background="{ThemeResource SimryxAccentBrush}"
                                                                    CornerRadius="6"
                                                                    Padding="6,1,6,1"
                                                                    VerticalAlignment="Center"
                                                                    Visibility="{Binding PriorityChipVisibility}">
                                                                <TextBlock x:Uid="ProfilePriorityChip"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#0E1116" />
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon FontSize="12"
                                                                      Glyph="&#xE9D9;"
                                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                            <TextBlock Text="{x:Bind StatsDisplay}"
                                                                       FontSize="12"
                                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                Spacing="8" VerticalAlignment="Center">
                                                        <Button Click="SetPriority_Click" Tag="{x:Bind}"
                                                                Height="36" Padding="12,0" CornerRadius="8"
                                                                Visibility="{Binding SetPriorityButtonVisibility}">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <FontIcon FontSize="14" Glyph="&#xE735;" />
                                                                <TextBlock x:Uid="ProfileSetPriority" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button Click="Edit_Click" Tag="{x:Bind}"
                                                                Width="36" Height="36" CornerRadius="8">
                                                            <FontIcon FontSize="14" Glyph="&#xE70F;" />
                                                        </Button>
                                                        <Button Click="Delete_Click" Tag="{x:Bind}"
                                                                Width="36" Height="36" CornerRadius="8">
                                                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Пустое состояние -->
        <StackPanel x:Name="EmptyState" Grid.Row="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="10" Visibility="Collapsed">
            <FontIcon Glyph="&#xE77B;" FontSize="40" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock x:Uid="ProfilesEmptyTitle" HorizontalAlignment="Center" FontWeight="SemiBold" />
            <TextBlock x:Uid="ProfilesEmptyText" HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</Page>