<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Simryx.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Simryx.App.Services">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Themes/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Глобальный микро-эффект наведения/нажатия для всех кнопок -->
            <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="svc:MicroInteractions.IsEnabled" Value="True" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>