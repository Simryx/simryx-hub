<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Simryx.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Simryx Hub">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Кастомный заголовок: иконка + название -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="40" Padding="12,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <Image Source="ms-appx:///Assets/Simryx.png" Width="20" Height="20" />
                <TextBlock Text="Simryx Hub" VerticalAlignment="Center" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <!-- Меню и контент -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            PaneDisplayMode="Left"
            PaneOpening="NavView_PaneOpening"
            PaneClosing="NavView_PaneClosing"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="NavDashboard" Tag="Dashboard">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Home" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="NavDevices" Tag="Devices">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Manage" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="NavTelemetry" Tag="Telemetry">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Repair" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="NavProfiles" Tag="Profiles">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Favorite" /></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- Splash-оверлей -->
        <Grid x:Name="SplashOverlay" Grid.Row="0" Grid.RowSpan="2"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <StackPanel x:Name="SplashContent" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="30">
                <!-- Логотип из трёх частей (накладываются друг на друга) -->
                <Grid x:Name="LogoContainer" Width="104" Height="104">
                    <Image x:Name="LogoPart1" Source="ms-appx:///Assets/LogoPart1.png" Stretch="Uniform" />
                    <Image x:Name="LogoPart2" Source="ms-appx:///Assets/LogoPart2.png" Stretch="Uniform" />
                    <Image x:Name="LogoPart3" Source="ms-appx:///Assets/LogoPart3.png" Stretch="Uniform" />
                </Grid>
                <ProgressRing x:Name="SplashRing" IsActive="True" Width="30" Height="30"
                              Foreground="{ThemeResource SimryxAccentBrush}"
                              HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>